VITE_ASSET_FORGE_API_BASE=
VITE_TELLUS_API_BASE=
VITE_TELLUS_GENERATION_PROVIDER=instantmesh-gradio
VITE_TELLUS_PLAYER_GENERATION_PROVIDER=instantmesh-gradio
VITE_TELLUS_AGENT_GENERATION_PROVIDER=pixal3d-gradio
VITE_TELLUS_AGENT_MODEL=GLM-5.1
VITE_TELLUS_WORLD_API_BASE=
VITE_TELLUS_WORLD_ID=main
VITE_TELLUS_SKYBOX_URL=/skybox/free_-_skybox_basic_sky.glb
VITE_TELLUS_JOHNNY_AVATAR_URL=/avatars/johnny.glb
VITE_TELLUS_MIRA_AVATAR_URL=/avatars/mira.glb
VITE_TELLUS_SOL_AVATAR_URL=/avatars/sol.glb
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=
ZAI_MODEL=GLM-5.1
ZAI_THINKING_TYPE=disabled
HYADES_BASE_URL=http://192.168.1.187
HYADES_API_KEY=
# Route 3D generation through the Hyades cluster (/3d/jobs) instead of the direct Gradio backends.
# Set to "hyades" to enable: instantmesh-gradio -> Hyades "instantmesh", pixal3d-gradio -> Hyades "pixal3d"
# (anigen-gradio stays on the legacy path). The browser flow is unchanged; the key stays server-side.
TELLUS_3D_BACKEND=
# Hyades base for /3d/jobs (defaults to the public edge https://hyades.gnostr.cloud). The bearer needs the
# 'generate3d' capability; HYADES_3D_API_KEY falls back to HYADES_API_KEY (the same key the TTS proxy uses).
HYADES_3D_API_BASE=https://hyades.gnostr.cloud
HYADES_3D_API_KEY=
INSTANTMESH_GRADIO_BASE_URL=http://192.168.1.177:43839
INSTANTMESH_SAMPLE_STEPS=30
PIXAL3D_GRADIO_BASE_URL=http://192.168.1.177:7860
TELLUS_TEXT_TO_IMAGE_PROVIDER=gradio
TELLUS_TEXT_TO_IMAGE_BASE_URL=http://192.168.1.173:7862
TELLUS_GRADIO_IMAGE_API_NAME=generate
TELLUS_GRADIO_IMAGE_PRESET=Square asset
ANIGEN_GRADIO_BASE_URL=http://192.168.1.177:7863
PIXAL3D_RESOLUTION=1536
PIXAL3D_PREVIEW_RESOLUTION=1024
PIXAL3D_PREVIEW_FRAMES=8
PIXAL3D_DECIMATION_TARGET=1000000
PIXAL3D_TEXTURE_SIZE=4096
PIXAL3D_SAMPLING_STEPS=12
PIXAL3D_TIMEOUT_MS=1200000
TELLUS_GENERATION_JOB_TIMEOUT_MS=2700000
TELLUS_GENERATION_QUEUED_TTL_MS=5400000
TELLUS_GENERATION_RUNNING_TTL_MS=5400000
ANIGEN_RIGGER=auto
ANIGEN_BIND=direct
ANIGEN_SS_MODEL=ss_flow_solo
ANIGEN_SLAT_MODEL=slat_flow_auto
ANIGEN_SS_STEPS=25
ANIGEN_SLAT_STEPS=25
ANIGEN_SIMPLIFY_RATIO=0.95
ANIGEN_TEXTURE_SIZE=1024
ANIGEN_ANIMATE=true
ANIGEN_MESH_REPAIR=true
TELLUS_OPTIMIZE_GLB=true
TELLUS_OPTIMIZE_QUANTIZE=true
TELLUS_OPTIMIZE_TEXTURES=true
TELLUS_OPTIMIZE_TEXTURE_MAX_SIZE=1024
TELLUS_OPTIMIZE_TEXTURE_QUALITY=82
TELLUS_OPTIMIZE_SIMPLIFY_RATIO=
TELLUS_OPTIMIZE_SIMPLIFY_ERROR=0.0001
TELLUS_ASSET_STORE_API_BASE=https://3d.flobots.xyz
TELLUS_ASSET_STORE_SESSION_COOKIE=
TELLUS_ASSET_STORE_UPLOAD_TOKEN=
TELLUS_REQUIRE_ASSET_STORE_UPLOAD=true
TELLUS_ASSET_STORE_PUBLIC=true
TELLUS_GENERATED_ASSET_DIR=Z:\3d\assets\tellus
