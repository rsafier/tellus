{
  "name": "tellus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "Tellus: a tiny AI terrarium where agents shape a floating world.",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --host --port 3344 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host --port 4344",
    "start": "bun server.ts",
    "instantmesh:setup": "bash scripts/setup-instantmesh.sh",
    "instantmesh:start": "bash scripts/start-instantmesh.sh",
    "bench:instantmesh": "bun scripts/benchmark-instantmesh.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@z_ai/mcp-server": "0.1.4",
    "lucide-react": "^0.577.0",
    "meshoptimizer": "^1.1.1",
    "nostr-tools": "^2.23.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "three": "0.183.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260605.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.183.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "vitest": "4.1.0",
    "wrangler": "^4.98.0"
  }
}
